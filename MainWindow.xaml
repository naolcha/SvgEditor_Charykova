<Window x:Class="SvgIconEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SVG Icon Editor"
        Width="1000"
        Height="650"
        MinWidth="850"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6"
        KeyDown="Window_KeyDown">

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#FF1F2937"
                Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="SVG Icon Editor"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <Button Content="Очистить"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="ClearCanvas_Click"/>

                <Button Content="Справка F1"
                        Width="110"
                        Height="34"
                        Click="Help_Click"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    Margin="10"
                    Padding="14"
                    CornerRadius="10"
                    BorderBrush="#FFD1D5DB"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Инструменты"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <UniformGrid Columns="1"
                                 Margin="0,0,0,18">
                        <Button Content="Линия"
                                Tag="Line"
                                Height="40"
                                Margin="0,0,0,8"
                                Click="ToolButton_Click"/>

                        <Button Content="Прямоугольник"
                                Tag="Rectangle"
                                Height="40"
                                Margin="0,0,0,8"
                                Click="ToolButton_Click"/>

                        <Button Content="Эллипс"
                                Tag="Ellipse"
                                Height="40"
                                Margin="0,0,0,8"
                                Click="ToolButton_Click"/>
                    </UniformGrid>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock Text="Текущий инструмент"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="ToolInfoText"
                               Text="Линия"
                               FontSize="15"
                               Margin="0,0,0,18"/>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock Text="Первая версия проекта"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,8"/>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="#FF374151"
                               FontSize="14"
                               Text="Минимальная версия: холст и три базовых инструмента. Дальше будут добавлены цвета, выбор объектов, текст, Undo/Redo, экспорт SVG и дополнительные фигуры."/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="10"
                    Background="White"
                    CornerRadius="10"
                    BorderBrush="#FFD1D5DB"
                    BorderThickness="1"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="DrawingCanvas"
                            Width="1200"
                            Height="800"
                            Background="White"
                            Focusable="True"
                            MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown"
                            MouseLeftButtonUp="DrawingCanvas_MouseLeftButtonUp"
                            MouseMove="DrawingCanvas_MouseMove"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
