<Window x:Class="SvgIconEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SVG Icon Editor"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6"
        KeyDown="Window_KeyDown">

	<DockPanel LastChildFill="True">

		<Border DockPanel.Dock="Top"
                Background="#FF1F2937"
                Padding="10">

			<StackPanel Orientation="Horizontal">

				<TextBlock Text="SVG Icon Editor"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

				<Button Content="Очистить"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="ClearCanvas_Click"/>

				<Button Content="Экспорт SVG"
                        Width="120"
                        Height="34"
                        Margin="0,0,16,0"
                        Click="ExportSvg_Click"/>

				<Button Content="Цвет линии"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="StrokeColor_Click"/>

				<Button Content="Цвет заливки"
                        Width="120"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="FillColor_Click"/>

				<Button Content="Цвет фона"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="BackgroundColor_Click"/>

				<CheckBox x:Name="FillEnabledCheckBox"
                          Content="Заливка"
                          Foreground="White"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="4,0,20,0"/>

				<Button Content="Справка F1"
                        Width="110"
                        Height="34"
                        Click="Help_Click"/>

			</StackPanel>
		</Border>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="260"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0"
                    Background="White"
                    Margin="10"
                    Padding="14"
                    CornerRadius="10"
                    BorderBrush="#FFD1D5DB"
                    BorderThickness="1">

				<StackPanel>

					<TextBlock Text="Инструменты"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

					<UniformGrid Columns="2"
                                 Rows="2"
                                 Margin="0,0,0,18">

						<Button Content="Выбор"
                                Tag="Select"
                                Height="42"
                                Margin="4"
                                Click="ToolButton_Click"/>

						<Button Content="Линия"
                                Tag="Line"
                                Height="42"
                                Margin="4"
                                Click="ToolButton_Click"/>

						<Button Content="Прямоуг."
                                Tag="Rectangle"
                                Height="42"
                                Margin="4"
                                Click="ToolButton_Click"/>

						<Button Content="Эллипс"
                                Tag="Ellipse"
                                Height="42"
                                Margin="4"
                                Click="ToolButton_Click"/>

					</UniformGrid>

					<Separator Margin="0,0,0,16"/>

					<TextBlock Text="Текущий инструмент"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,8"/>

					<TextBlock x:Name="ToolInfoText"
                               Text="Выбор"
                               FontSize="15"
                               Margin="0,0,0,18"/>

					<TextBlock Text="Цвета"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,10"/>

					<StackPanel Orientation="Horizontal"
                                Margin="0,0,0,8">

						<TextBlock Text="Линия:"
                                   Width="70"
                                   VerticalAlignment="Center"/>

						<Border x:Name="StrokePreview"
                                Width="34"
                                Height="34"
                                BorderBrush="#FF6B7280"
                                BorderThickness="1"
                                Background="Black"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal"
                                Margin="0,0,0,8">

						<TextBlock Text="Заливка:"
                                   Width="70"
                                   VerticalAlignment="Center"/>

						<Border x:Name="FillPreview"
                                Width="34"
                                Height="34"
                                BorderBrush="#FF6B7280"
                                BorderThickness="1"
                                Background="#66A7F3D0"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal">

						<TextBlock Text="Фон:"
                                   Width="70"
                                   VerticalAlignment="Center"/>

						<Border x:Name="BackgroundPreview"
                                Width="34"
                                Height="34"
                                BorderBrush="#FF6B7280"
                                BorderThickness="1"
                                Background="White"/>
					</StackPanel>

					<Separator Margin="0,18,0,18"/>

					<TextBlock Text="Подсказка"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,8"/>

					<TextBlock TextWrapping="Wrap"
                               Foreground="#FF374151"
                               FontSize="14"
                               Text="Это вторая версия редактора. Теперь можно менять цвета линии, заливки и фона, а также экспортировать рисунок в SVG."/>

				</StackPanel>
			</Border>

			<Border Grid.Column="1"
                    Margin="10"
                    Background="White"
                    CornerRadius="10"
                    BorderBrush="#FFD1D5DB"
                    BorderThickness="1"
                    ClipToBounds="True">

				<ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">

					<Canvas x:Name="DrawingCanvas"
                            Width="1600"
                            Height="1000"
                            Background="White"
                            Focusable="True"
                            MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown"
                            MouseLeftButtonUp="DrawingCanvas_MouseLeftButtonUp"
                            MouseMove="DrawingCanvas_MouseMove"/>

				</ScrollViewer>
			</Border>
		</Grid>
	</DockPanel>
</Window>
